# --- App Configuration ---
APP_NAME=Resume Rankeing And Job Description Matching System
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO
APP_PORT=8501

# --- File Upload Settings ---
UPLOAD_FOLDER=uploads/
ALLOWED_EXTENSIONS=pdf,docx,doc,txt
MAX_FILE_SIZE_MB=10

# --- NLP & ML Model Configuration ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
MODEL_PATH=models/ranking_model.pkl
TFIDF_PATH=models/tfidf_vectorizer.pkl

# --- Resume Processing ---
ENABLE_PREPROCESSING=True
REMOVE_STOPWORDS=True
ENABLE_LEMMATIZATION=True
MIN_SKILL_MATCH=0.40

# --- Candidate Scoring Weights ---
# Total must equal 1.0
WEIGHT_SKILLS=0.45
WEIGHT_EXPERIENCE=0.30
WEIGHT_EDUCATION=0.15
WEIGHT_SEMANTIC=0.10

# --- Dashboard Settings ---
ENABLE_ANALYTICS=True
ENABLE_VISUALIZATION=True
DEFAULT_CHART_THEME=light

# --- Database (Optional Future Use) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intellihire
DB_USER=admin
DB_PASSWORD=password

# --- Security ---
SECRET_KEY=your_secret_key_here

# --- API Integration (Future Enhancement) ---
ENABLE_API=False
API_VERSION=v1